APP_NAME="Rosberg Wiki"
VITE_APP_NAME="Rosberg Wiki"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8086

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ─────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=wiki
DB_USERNAME=wiki
DB_PASSWORD=secret

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# ─── Exposed ports (host machine) ─────────────────────────────────────────────
NGINX_PORT=8086
DB_PORT_EXPOSE=5433
REDIS_PORT_EXPOSE=6380

# ─── LLM Providers (заполните нужный) ────────────────────────────────────────
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# Ollama (если используете локально)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Активный провайдер: openai | anthropic | ollama
LLM_PROVIDER=openai

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5051
